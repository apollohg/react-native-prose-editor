{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["react"]
  },
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
